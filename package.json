    "@types/react-dom": "^19.0.0",
    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/browser-playwright": "^4.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.6",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.2.0"
