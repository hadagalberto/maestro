{
  "name": "maestro",
  "version": "0.2.2",
  "description": "Desktop app para orquestrar CLIs de IA em grid de terminais",
  "main": "out/main/index.js",
  "bin": {
    "maestro": "bin/maestro.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hadagalberto/maestro.git"
  },
  "author": "Hadagalberto Junior",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project pane",
    "test:e2e": "playwright test"
  },
  "dependencies": {
